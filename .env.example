# Notion integration (mentor apply + services request forms)
# Create an internal integration at https://www.notion.com/my-integrations
# and share the target database(s) with it
NOTION_API_TOKEN=
NOTION_MENTOR_DATABASE_ID=
# Services request form → Notion DB with columns: Name (title), Email (email),
# Telegram (text), Phone (phone), Service (select), Budget (text),
# Timeline (text), Details (text)
NOTION_SERVICES_DATABASE_ID=
